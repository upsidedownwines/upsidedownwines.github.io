---
import Layout from '../layouts/Layout.astro';
import destinations from '../data/destinations.json';

interface Destination {
    id: string;
    name: string;
    description: string;
    image_url: string;
}
---

<Layout title="Our Wine Destinations">
    <main class="max-w-6xl mx-auto py-12 px-4">
        <h1 class="text-5xl font-extrabold text-gray-900 mb-8 text-center">Discover Our Exquisite Wine Destinations</h1>
        <p class="text-xl text-gray-700 mb-12 text-center max-w-3xl mx-auto">Embark on a journey through the world's most renowned wine regions, each offering a unique blend of culture, history, and unparalleled flavors.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {destinations.map((destination) => (
                <div class="bg-white rounded-xl shadow-lg overflow-hidden transform transition duration-300 hover:scale-105 hover:shadow-xl">
                    {/* <img src={destination.image_url} alt={destination.name} class="w-full h-56 object-cover" /> */}
                    <div class="p-8">
                        <h2 class="text-3xl font-bold text-gray-800 mb-3">{destination.name}</h2>
                        <p class="text-gray-600 leading-relaxed">{destination.description}</p>
                        <a href={`/destinations/${destination.id}`} class="mt-6 inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition duration-300 font-semibold">
                            Explore More
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </main>
</Layout>
