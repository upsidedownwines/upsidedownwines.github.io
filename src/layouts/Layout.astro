---
import '../styles/global.css';
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-emerald-50 text-gray-900 font-sans antialiased">
		<div class="fixed inset-0 -z-10 opacity-10" style="background-image: url('/vine_pattern.jpg'); background-repeat: repeat; background-size: 200px;"></div>
		<slot />
	</body>
</html>
